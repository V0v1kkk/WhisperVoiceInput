<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WhisperVoiceInput.ViewModels"
        xmlns:ab="using:WhisperVoiceInput.Abstractions"
        xmlns:b="using:WhisperVoiceInput.Behaviors"
        x:Class="WhisperVoiceInput.Views.LogWindow"
        Width="900" Height="600"
        Title="Log"
        x:DataType="vm:LogWindowViewModel">
  <Design.DataContext>
    <vm:LogWindowViewModel />
  </Design.DataContext>
  <Grid RowDefinitions="Auto,*,Auto" Margin="8">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Minimum level:" VerticalAlignment="Center"/>
      <ComboBox ItemsSource="{Binding Levels}"
                SelectedItem="{Binding SelectedLevel}" Width="180"/>
      <Button Content="Open Logs Folder" Margin="16,0,0,0" Click="OnOpenLogsFolderClick"/>
    </StackPanel>
    <ListBox x:Name="LogList" Grid.Row="1"
             ItemsSource="{Binding Items}"
             SelectionMode="Single"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             Margin="0,8,0,0">
      <b:AutoScroll.IsEnabled>
        <Binding Path="AutoScrollEnabled"/>
      </b:AutoScroll.IsEnabled>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <SelectableTextBlock x:DataType="ab:LogRecord"
                               Text="{Binding Formatted}"
                               Background="Transparent"
                               TextWrapping="Wrap"/>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
      <CheckBox IsChecked="{Binding AutoScrollEnabled}" Content="Autoscroll enabled"/>
    </StackPanel>
  </Grid>
</Window>




